   "source": [
    "PI=3.1415926535897\n",
    "def circle_area(radius):\n",
    "    return PI*radius**2\n",
    "\n",
    "def circle_perimeter(radius):\n",
    "    return PI*radius*radius\n",
    "\n",
    "circle_area(5)\n",
    "print(circle_area(5))\n",
    "print(circle_perimeter(6))"
   ]
